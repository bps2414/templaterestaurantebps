{
    "name": "restaurant-template-server",
    "version": "2.0.0",
    "description": "Template Premium de Site para Restaurante — Express + Prisma + Stripe",
    "main": "dist/index.js",
    "scripts": {
        "dev": "ts-node-dev --respawn --transpile-only src/index.ts",
        "select-theme": "node ../scripts/select-theme.js",
        "build": "tsc",
        "start": "node dist/index.js",
        "start:render": "sh scripts/start.sh",
        "prisma:generate": "prisma generate",
        "prisma:migrate": "prisma migrate dev",
        "prisma:migrate:deploy": "prisma migrate deploy",
        "prisma:seed": "ts-node prisma/seed.ts",
        "prisma:studio": "prisma studio",
        "change-plan": "ts-node scripts/change-plan.ts",
        "backup": "ts-node scripts/backup.ts",
        "backup:restore": "ts-node scripts/backup.ts restore",
        "test": "jest --forceExit --detectOpenHandles",
        "lint": "eslint src/ --ext .ts",
        "format": "prettier --write \"src/**/*.ts\"",
        "preflight": "powershell -ExecutionPolicy Bypass -File ../scripts/preflight.ps1",
        "dev:confeitaria": "cross-env THEME=confeitaria node ../scripts/select-theme.js && cross-env THEME=confeitaria ts-node-dev --respawn --transpile-only src/index.ts",
        "seed:confeitaria": "cross-env SEED_TYPE=confeitaria ts-node prisma/seed.ts",
        "dev:pizzaria": "cross-env THEME=pizzaria node ../scripts/select-theme.js && cross-env THEME=pizzaria ts-node-dev --respawn --transpile-only src/index.ts",
        "seed:pizzaria": "cross-env SEED_TYPE=pizzaria ts-node prisma/seed.ts",
        "dev:restaurant-lite": "cross-env THEME=restaurant-lite PLAN=starter node ../scripts/select-theme.js && cross-env THEME=restaurant-lite PLAN=starter ts-node-dev --respawn --transpile-only src/index.ts",
        "seed:restaurant-lite": "cross-env SEED_TYPE=restaurant-lite PLAN=starter ts-node prisma/seed.ts",
        "dev:burger-lite": "cross-env THEME=burger-lite PLAN=starter node ../scripts/select-theme.js && cross-env THEME=burger-lite PLAN=starter ts-node-dev --respawn --transpile-only src/index.ts",
        "seed:burger-lite": "cross-env SEED_TYPE=burger-lite PLAN=starter ts-node prisma/seed.ts",
        "dev:pizza-lite": "cross-env THEME=pizza-lite PLAN=starter node ../scripts/select-theme.js && cross-env THEME=pizza-lite PLAN=starter ts-node-dev --respawn --transpile-only src/index.ts",
        "seed:pizza-lite": "cross-env SEED_TYPE=pizza-lite PLAN=starter ts-node prisma/seed.ts",
        "dev:acai": "cross-env THEME=acai PLAN=starter node ../scripts/select-theme.js && cross-env THEME=acai PLAN=starter ts-node-dev --respawn --transpile-only src/index.ts",
        "seed:acai": "cross-env SEED_TYPE=acai PLAN=starter ts-node prisma/seed.ts"
    },
    "prisma": {
        "seed": "ts-node prisma/seed.ts"
    },
    "dependencies": {
        "@prisma/client": "5.22.0",
        "bcryptjs": "^2.4.3",
        "cloudinary": "^2.9.0",
        "compression": "^1.8.1",
        "cookie-parser": "^1.4.6",
        "cors": "^2.8.5",
        "express": "^4.18.2",
        "express-rate-limit": "^7.5.1",
        "helmet": "^7.2.0",
        "jsonwebtoken": "^9.0.2",
        "morgan": "^1.10.0",
        "multer": "^2.0.0",
        "uuid": "^9.0.0",
        "winston": "^3.19.0",
        "zod": "^3.22.4"
    },
    "devDependencies": {
        "@types/bcryptjs": "^2.4.6",
        "@types/compression": "^1.8.1",
        "@types/cookie-parser": "^1.4.6",
        "@types/cors": "^2.8.17",
        "@types/express": "^4.17.21",
        "@types/express-rate-limit": "^5.1.3",
        "@types/jest": "^30.0.0",
        "@types/jsonwebtoken": "^9.0.5",
        "@types/morgan": "^1.9.9",
        "@types/multer": "^1.4.11",
        "@types/node": "^22.0.0",
        "@types/supertest": "^6.0.3",
        "@types/uuid": "^9.0.7",
        "cross-env": "^10.1.0",
        "jest": "^30.2.0",
        "prisma": "5.22.0",
        "supertest": "^7.2.2",
        "ts-jest": "^29.4.6",
        "ts-node": "^10.9.2",
        "ts-node-dev": "^2.0.0",
        "typescript": "^5.3.3"
    },
    "engines": {
        "node": ">=22.0.0"
    }
}