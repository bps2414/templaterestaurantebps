# ============================================
# FluxPay SaaS — Environment Variables
# Copy this file to .env and fill in the values
# ============================================

# --- Database ---
DATABASE_URL=postgresql://postgres:password@db:5432/fluxpay

# --- Redis ---
REDIS_URL=redis://redis:6379

# --- JWT ---
JWT_SECRET=replace_me_with_a_long_random_string_minimum_32_chars
JWT_ACCESS_EXP=15m
JWT_REFRESH_EXP=30d

# --- Stripe ---
STRIPE_SECRET_KEY=sk_test_xxx
STRIPE_WEBHOOK_SECRET=whsec_xxx
STRIPE_STARTER_PRICE_ID=price_starter_xxx
STRIPE_PRO_PRICE_ID=price_pro_xxx
STRIPE_BUSINESS_PRICE_ID=price_business_xxx

# --- SendGrid ---
SENDGRID_API_KEY=SG.xxx
SENDGRID_FROM_EMAIL=noreply@fluxpay.com.br
SENDGRID_FROM_NAME=FluxPay

# --- Cloudinary ---
CLOUDINARY_CLOUD_NAME=your-cloud-name
CLOUDINARY_API_KEY=123456789012345
CLOUDINARY_API_SECRET=your-api-secret

# --- App ---
APP_URL=http://localhost:3000
PORT=3000
NODE_ENV=development

# --- Sentry (optional) ---
SENTRY_DSN=

# --- Admin seed ---
ADMIN_EMAIL=admin@fluxpay.com.br
ADMIN_PASSWORD=Admin@123456
